<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
        android:layout_height="match_parent"
            android:orientation="vertical"
                android:padding="16dp"
                    android:background="#121212">

                        <TextView
                                android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                                android:text="RootSpoofer"
                                                        android:textSize="28sp"
                                                                android:textColor="#00E676"
                                                                        android:textStyle="bold"
                                                                                android:layout_marginBottom="8dp"/>

                                                                                    <TextView
                                                                                            android:layout_width="wrap_content"
                                                                                                    android:layout_height="wrap_content"
                                                                                                            android:text="Patch any APK to fake root detection"
                                                                                                                    android:textColor="#888"
                                                                                                                            android:layout_marginBottom="24dp"/>

                                                                                                                                <Button
                                                                                                                                        android:id="@+id/btnSelectApk"
                                                                                                                                                android:layout_width="match_parent"
                                                                                                                                                        android:layout_height="56dp"
                                                                                                                                                                android:text="SELECT TARGET APK"
                                                                                                                                                                        android:backgroundTint="#00E676"
                                                                                                                                                                                android:textColor="#121212"
                                                                                                                                                                                        android:textStyle="bold"/>

                                                                                                                                                                                            <TextView
                                                                                                                                                                                                    android:id="@+id/tvSelectedApk"
                                                                                                                                                                                                            android:layout_width="match_parent"
                                                                                                                                                                                                                    android:layout_height="wrap_content"
                                                                                                                                                                                                                            android:text="No APK selected"
                                                                                                                                                                                                                                    android:textColor="#888"
                                                                                                                                                                                                                                            android:padding="8dp"
                                                                                                                                                                                                                                                    android:layout_marginTop="8dp"/>

                                                                                                                                                                                                                                                        <LinearLayout
                                                                                                                                                                                                                                                                android:layout_width="match_parent"
                                                                                                                                                                                                                                                                        android:layout_height="wrap_content"
                                                                                                                                                                                                                                                                                android:orientation="horizontal"
                                                                                                                                                                                                                                                                                        android:layout_marginTop="16dp">

                                                                                                                                                                                                                                                                                                <CheckBox
                                                                                                                                                                                                                                                                                                            android:id="@+id/cbInjectFrida"
                                                                                                                                                                                                                                                                                                                        android:layout_width="0dp"
                                                                                                                                                                                                                                                                                                                                    android:layout_height="wrap_content"
                                                                                                                                                                                                                                                                                                                                                android:layout_weight="1"
                                                                                                                                                                                                                                                                                                                                                            android:text="Inject Frida Gadget"
                                                                                                                                                                                                                                                                                                                                                                        android:textColor="#ccc"
                                                                                                                                                                                                                                                                                                                                                                                    android:checked="true"/>

                                                                                                                                                                                                                                                                                                                                                                                            <CheckBox
                                                                                                                                                                                                                                                                                                                                                                                                        android:id="@+id/cbAutoInstall"
                                                                                                                                                                                                                                                                                                                                                                                                                    android:layout_width="0dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                android:layout_height="wrap_content"
                                                                                                                                                                                                                                                                                                                                                                                                                                            android:layout_weight="1"
                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:text="Auto Install"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:textColor="#ccc"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:checked="true"/>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </LinearLayout>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <Button
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:id="@+id/btnPatch"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:layout_width="match_parent"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:layout_height="56dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:text="PATCH APK"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:backgroundTint="#FF5722"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:textColor="#fff"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:textStyle="bold"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:layout_marginTop="16dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:enabled="false"/>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <ProgressBar
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            android:id="@+id/progressBar"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    style="?android:attr/progressBarStyleHorizontal"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            android:layout_width="match_parent"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:layout_height="4dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            android:layout_marginTop="16dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:visibility="gone"/>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <TextView
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:id="@+id/tvStatus"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:layout_width="match_parent"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:layout_height="wrap_content"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:text="Ready"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:textColor="#aaa"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:padding="8dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:layout_marginTop="8dp"/>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     <ScrollView
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             android:id="@+id/scrollView"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             android:layout_width="match_parent"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:layout_height="0dp"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            android:layout_weight="1"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:layout_marginTop="8dp">

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <TextView
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:id="@+id/tvLog"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:layout_width="match_parent"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                android:layout_height="wrap_content"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            android:textColor="#ccc"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        android:typeface="monospace"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    android:textSize="11sp"/>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </ScrollView>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </LinearLayout>